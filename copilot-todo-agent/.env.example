# ── LLM (Azure OpenAI) ────────────────────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Azure AD app registration ─────────────────────────────────────────────────
# Required for: Microsoft Graph API (Todo) + Copilot Studio auth
AZURE_CLIENT_ID=your-app-client-id
AZURE_TENANT_ID=your-tenant-id
AZURE_CLIENT_SECRET=your-app-client-secret

# ── Microsoft Todo (via Microsoft Graph) ──────────────────────────────────────
# AZURE_TODO_USER_ID: the Object ID of the user whose Todo list will be used
# AZURE_TODO_LIST_ID: ID of the specific Microsoft Todo list to create tasks in
AZURE_TODO_USER_ID=user-object-id-in-azure-ad
AZURE_TODO_LIST_ID=microsoft-todo-list-id

# ── Copilot Studio connection (required only for --mode copilot) ───────────────
COPILOTSTUDIOAGENT__ENVIRONMENTID=your-power-platform-environment-id
COPILOTSTUDIOAGENT__SCHEMANAME=your-copilot-studio-agent-schema-name
COPILOTSTUDIOAGENT__AGENTAPPID=your-copilot-studio-app-id
COPILOTSTUDIOAGENT__TENANTID=your-tenant-id
